{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "nixpacks": false,
    "providers": ["nodejs"],
    "nodejs": {
      "openssl": true
    }
  },
  "deploy": {
    "startCommand": "sh -c 'cd backend && node prisma-push.js && cd .. && node backend/src/index.js'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
